---
import { packages } from "@/data/site";
---

<div class="package-grid">
  {packages.map((pkg) => (
    <article class={`package card ${pkg.featured ? "featured" : ""}`}>
      <div class="package-top">
        <span class={`pill ${pkg.featured ? "yellow" : ""}`}>{pkg.badge}</span>
        <h3>{pkg.name}</h3>
        <p class="price">{pkg.price}</p>
        <p>{pkg.bestFor}</p>
      </div>
      <div>
        <h4>Includes</h4>
        <ul class="list">
          {pkg.includes.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div>
        <h4>Not included by default</h4>
        <ul class="mini-list">
          {pkg.excludes.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <a class={`btn ${pkg.featured ? "primary" : "secondary"}`} href="/free-audit">{pkg.cta}</a>
    </article>
  ))}
</div>

<style>
  .package-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    align-items: stretch;
  }

  .package {
    position: relative;
    display: grid;
    gap: 24px;
  }

  .featured {
    border-color: var(--primary);
    background:
      radial-gradient(circle at 14px 14px, rgba(5, 5, 5, 0.12) 2px, transparent 2.5px) 0 0 / 28px 28px,
      linear-gradient(135deg, var(--primary), #fff3a8 44%, #ffffff),
      var(--surface-card);
    box-shadow: 10px 10px 0 var(--pink);
    transform: translateY(-10px);
  }

  .featured::before {
    content: "";
    position: absolute;
    inset: -1px;
    pointer-events: none;
    border-radius: inherit;
    border: 5px solid var(--ink);
    background: linear-gradient(135deg, rgba(255, 47, 145, 0.22), transparent 24%, transparent 72%, rgba(4, 150, 255, 0.22));
    opacity: 1;
  }

  .package-top {
    display: grid;
    gap: 14px;
  }

  h3 {
    font-size: 28px;
  }

  h4 {
    margin: 0 0 12px;
    color: var(--ink);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }

  .price {
    color: var(--red);
    font-family: var(--font-heavy);
    font-size: 20px;
    font-weight: 900;
    text-transform: uppercase;
  }

  .mini-list {
    display: grid;
    gap: 8px;
    margin: 0;
    padding-left: 18px;
    color: var(--muted);
    font-size: 14px;
  }

  @media (max-width: 980px) {
    .package-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
