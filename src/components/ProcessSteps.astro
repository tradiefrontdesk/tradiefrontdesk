---
import { processSteps } from "@/data/site";

interface Props {
  title?: string;
  text?: string;
}

const { title = "How The System Works", text = "A simple five-step flow for handling enquiries from first contact to follow-up." } = Astro.props;
---

<section class="section band">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">Capture → Respond → Qualify → Book → Follow Up</p>
      <h2>{title}</h2>
      <p class="lead">{text}</p>
    </div>
    <div class="steps">
      {processSteps.map((step, index) => (
        <article class="step">
          <span>{index + 1}</span>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .steps {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .step {
    position: relative;
    display: grid;
    gap: 14px;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    background: var(--canvas);
    padding: 22px;
  }

  .step:not(:last-child)::after {
    content: "";
    position: absolute;
    top: 38px;
    right: -13px;
    z-index: 1;
    width: 24px;
    height: 2px;
    background: linear-gradient(90deg, var(--primary), transparent);
    box-shadow: 0 0 18px rgba(204, 120, 92, 0.45);
  }

  span {
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border-radius: var(--radius-sm);
    background: var(--primary);
    color: var(--on-primary);
    font-weight: 850;
    box-shadow: 0 0 26px rgba(204, 120, 92, 0.2);
  }

  h3 {
    font-size: 21px;
  }

  @media (max-width: 1040px) {
    .steps {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .step::after {
      display: none;
    }
  }

  @media (max-width: 620px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>
