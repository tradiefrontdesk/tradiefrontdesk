---
import { processSteps } from "@/data/site";

interface Props {
  title?: string;
  text?: string;
}

const { title = "How The System Works", text = "A simple five-step flow for handling enquiries from first contact to follow-up." } = Astro.props;
---

<section class="section band">
  <div class="container">
    <div class="section-head">
      <p class="eyebrow">Capture → Respond → Qualify → Book → Follow Up</p>
      <h2>{title}</h2>
      <p class="lead">{text}</p>
    </div>
    <div class="steps">
      {processSteps.map((step, index) => (
        <article class="step">
          <span>{index + 1}</span>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .steps {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .step {
    position: relative;
    display: grid;
    gap: 14px;
    border: 5px solid var(--ink);
    background: var(--surface-card);
    padding: 22px;
    box-shadow: 6px 6px 0 var(--ink);
  }

  .step:not(:last-child)::after {
    content: "";
    position: absolute;
    top: 38px;
    right: -13px;
    z-index: 1;
    width: 30px;
    height: 8px;
    background: var(--red);
    box-shadow: 3px 3px 0 var(--ink);
  }

  span {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border: 4px solid var(--ink);
    border-radius: 999px;
    background: var(--red);
    color: var(--on-dark);
    font-family: var(--font-heavy);
    font-weight: 900;
    box-shadow: 4px 4px 0 var(--ink);
  }

  h3 {
    font-size: 34px;
  }

  @media (max-width: 1040px) {
    .steps {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .step::after {
      display: none;
    }
  }

  @media (max-width: 620px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>
