---
import { navItems } from "@/data/site";
---

<header class="site-header">
  <div class="container nav">
    <a class="brand" href="/" aria-label="Tradie Front Desk home">
      <span class="mark">TFD</span>
      <span>
        <strong>Tradie Front Desk</strong>
        <small>by System Pros AI</small>
      </span>
    </a>
    <nav aria-label="Primary navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a class="btn primary nav-cta" href="/free-audit">Book Free Audit</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--hairline);
    background: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(16px);
  }

  .nav {
    display: flex;
    min-height: 72px;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--ink);
    min-width: max-content;
  }

  .mark {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border-radius: 8px;
    background: var(--primary);
    color: var(--on-primary);
    font-size: 13px;
    font-weight: 850;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand strong {
    font-size: 15px;
    line-height: 1.1;
  }

  .brand small {
    color: var(--muted);
    font-size: 12px;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  nav a {
    color: var(--body);
    font-size: 14px;
    font-weight: 600;
  }

  nav a:hover {
    color: var(--ink);
  }

  .nav-cta {
    min-width: max-content;
  }

  @media (max-width: 1040px) {
    nav {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .nav {
      min-height: 64px;
    }

    .brand small {
      display: none;
    }

    .nav-cta {
      min-height: 38px;
      padding: 10px 12px;
      width: auto;
    }
  }
</style>
