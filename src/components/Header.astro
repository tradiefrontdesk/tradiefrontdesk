---
import { brand, navItems } from "@/data/site";
---

<header class="site-header">
  <div class="container nav">
    <a class="brand" href="/" aria-label="Tradie Front Desk home">
      <span class="mark">
        <img src={brand.logo} alt="" width="36" height="36" loading="eager" />
      </span>
      <strong>{brand.name}</strong>
    </a>
    <nav aria-label="Primary navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a class="btn primary nav-cta" href="/free-audit">Book Free Audit</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 5px solid var(--ink);
    background:
      radial-gradient(circle at 10px 10px, rgba(5, 5, 5, 0.14) 2px, transparent 2.5px) 0 0 / 24px 24px,
      var(--primary);
    box-shadow: 0 6px 0 var(--ink);
  }

  .nav {
    display: flex;
    min-height: 72px;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--ink);
    min-width: max-content;
  }

  .mark {
    display: grid;
    width: 44px;
    height: 44px;
    flex: 0 0 auto;
    place-items: center;
    overflow: hidden;
    border: 4px solid var(--ink);
    background: var(--surface-card);
    box-shadow: 4px 4px 0 var(--ink);
  }

  .mark img {
    width: 42px;
    height: 42px;
    object-fit: contain;
  }

  .brand strong {
    font-family: var(--font-heavy);
    font-size: 21px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0.2px;
    text-transform: uppercase;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  nav a {
    position: relative;
    color: var(--ink);
    font-size: 14px;
    font-weight: 900;
    text-transform: uppercase;
  }

  nav a:hover {
    color: var(--red);
  }

  .nav-cta {
    min-width: max-content;
  }

  @media (max-width: 1040px) {
    nav {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .nav {
      min-height: 64px;
    }

    .nav-cta {
      min-height: 38px;
      padding: 10px 12px;
      width: auto;
    }
  }
</style>
