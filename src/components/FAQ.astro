---
import TradieTestimonials from "@/components/TradieTestimonials";
import { faqs } from "@/data/site";

interface Props {
  items?: [string, string][];
  title?: string;
}

const { items = faqs, title = "Common Questions" } = Astro.props;
---

<section class="section">
  <div class="container faq-wrap">
    <TradieTestimonials client:visible />
    <div class="section-head">
      <p class="eyebrow">FAQ</p>
      <h2>{title}</h2>
    </div>
    <div class="faq-list">
      {items.map(([question, answer]) => (
        <details>
          <summary>{question}</summary>
          <p>{answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-wrap {
    max-width: 920px;
  }

  .faq-list {
    display: grid;
    gap: 12px;
  }

  details {
    border: 4px solid var(--ink);
    background: var(--surface-card);
    padding: 18px 20px;
    box-shadow: 5px 5px 0 var(--ink);
  }

  summary {
    cursor: pointer;
    color: var(--ink);
    font-family: var(--font-heavy);
    font-size: 20px;
    font-weight: 900;
    text-transform: uppercase;
  }

  p {
    margin-top: 12px;
    color: var(--body);
  }
</style>
