---
import TradieTestimonials from "@/components/TradieTestimonials";
import { faqs } from "@/data/site";

interface Props {
  items?: [string, string][];
  title?: string;
}

const { items = faqs, title = "Common Questions" } = Astro.props;
---

<section class="section">
  <div class="container faq-wrap">
    <TradieTestimonials client:visible />
    <div class="section-head">
      <p class="eyebrow">FAQ</p>
      <h2>{title}</h2>
    </div>
    <div class="faq-list">
      {items.map(([question, answer]) => (
        <details>
          <summary>{question}</summary>
          <p>{answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-wrap {
    max-width: 920px;
  }

  .faq-list {
    display: grid;
    gap: 12px;
  }

  details {
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    background: var(--surface-card);
    padding: 18px 20px;
  }

  summary {
    cursor: pointer;
    color: var(--ink);
    font-weight: 750;
  }

  p {
    margin-top: 12px;
    color: var(--body);
  }
</style>
