---
import ProductVideoPlayer from "@/components/ProductVideoPlayer";
import { videoById, type VideoId } from "@/remotion/data/homeVideos";

interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  primary?: string;
  primaryHref?: string;
  secondary?: string;
  secondaryHref?: string;
  bullets?: string[];
  videoId?: VideoId | false;
}

const { eyebrow, title, text, primary = "Book a Free Front Desk Audit", primaryHref = "/free-audit", secondary, secondaryHref = "/how-it-works", bullets = [], videoId = "HomeHeroVideo" } = Astro.props;
const heroVideo = videoId ? videoById[videoId] : null;
---

<section class="hero section">
  <div class="container split">
    <div class="hero-copy">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p class="lead">{text}</p>
      <div class="button-row">
        <a class="btn primary" href={primaryHref}>{primary}</a>
        {secondary && <a class="btn secondary" href={secondaryHref}>{secondary}</a>}
      </div>
      {bullets.length > 0 && (
        <ul class="hero-bullets">
          {bullets.map((bullet) => <li>{bullet}</li>)}
        </ul>
      )}
    </div>
    <div class="hero-panel">
      {heroVideo && (
        <ProductVideoPlayer
          id={heroVideo.id}
          title={heroVideo.title}
          description={heroVideo.description}
          bare
          featured
          autoplay
          client:load
        />
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    overflow: hidden;
    min-height: calc(100vh - 72px);
    padding-top: 92px;
    border-bottom: 6px solid var(--ink);
    background:
      linear-gradient(120deg, rgba(4, 150, 255, 0.94) 0 48%, rgba(255, 217, 0, 0.9) 48% 100%),
      var(--primary);
  }

  .hero::before {
    opacity: 0.2;
  }

  .hero::after {
    content: "WANTED";
    position: absolute;
    top: 24px;
    right: -22px;
    border: 5px solid var(--ink);
    background: var(--red);
    color: var(--on-dark);
    padding: 8px 22px;
    font-family: var(--font-heavy);
    font-size: clamp(28px, 5vw, 76px);
    line-height: 1;
    box-shadow: 7px 7px 0 var(--ink);
    transform: rotate(7deg);
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 24px;
  }

  .hero-copy .lead {
    max-width: 740px;
    border: 5px solid var(--ink);
    background: var(--surface-card);
    padding: 20px;
    box-shadow: var(--comic-shadow);
  }

  .hero-bullets {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px 16px;
    margin: 8px 0 0;
    padding: 0;
    list-style: none;
    color: var(--ink);
    font-size: 15px;
    font-weight: 900;
  }

  .hero-bullets li::before {
    content: "✓";
    color: var(--red);
    font-weight: 800;
    margin-right: 8px;
  }

  .hero-panel {
    position: relative;
    z-index: 1;
    min-width: 0;
    transform: rotate(1.5deg);
  }

  .hero-panel :global(.product-video) {
    padding: 14px;
  }

  @media (max-width: 720px) {
    .hero {
      min-height: auto;
      padding-top: 70px;
    }

    .hero::after {
      top: 10px;
      right: -12px;
      font-size: 32px;
    }

    .hero-bullets {
      grid-template-columns: 1fr;
    }

  }
</style>
