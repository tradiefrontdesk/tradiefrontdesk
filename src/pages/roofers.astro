---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import CTASection from "@/components/CTASection.astro";
import HeroMarquee from "@/components/HeroMarquee.astro";
import SectionVideo from "@/components/SectionVideo.astro";
import { tradePages } from "@/data/site";

const page = tradePages.roofers;
const examples = [...page.examples];
---

<BaseLayout title="Roofing Front Desk System | Tradie Front Desk" description="Capture roof inspection requests, reply fast, book site visits, and follow up high-value roofing quotes.">
  <Hero eyebrow={page.eyebrow} title={page.title} text={page.text} primary={page.cta} primaryHref="/free-audit" secondary="View Pricing" secondaryHref="/pricing" videoId="PricingPackagesVideo" />
  <HeroMarquee eyebrow="Roofing enquiry examples" items={examples} />
  <section class="section band">
    <div class="container split video-split">
      <div class="section-head">
        <p class="eyebrow">Example flow</p>
        <h2>{page.flow}</h2>
        <p class="lead">One missed inspection request or unfollowed high-value quote can be worth more than the monthly system fee.</p>
      </div>
      <SectionVideo id="PricingPackagesVideo" />
    </div>
  </section>
  <section class="section">
    <div class="container grid two">
      {page.examples.map((item) => <article class="card"><h3>{item}</h3><p>Capture the request, reply fast, move the customer toward inspection, and follow up the quote professionally.</p></article>)}
    </div>
  </section>
  <section class="section band">
    <div class="container grid two">
      {page.objections.map((item) => <article class="card"><h3>High-value quote protection</h3><p>{item}</p></article>)}
    </div>
  </section>
  <CTASection title="Book A Free Roofing Front Desk Audit" text="We will review inspection requests, quote follow-up, missed calls, and the handoff process behind your roofing enquiries." cta={page.cta} />
</BaseLayout>
