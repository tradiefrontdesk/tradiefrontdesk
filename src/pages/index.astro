---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import FeatureGrid from "@/components/FeatureGrid.astro";
import ProcessSteps from "@/components/ProcessSteps.astro";
import PackageCards from "@/components/PackageCards.astro";
import CaseStudyCard from "@/components/CaseStudyCard.astro";
import CTASection from "@/components/CTASection.astro";
import FAQ from "@/components/FAQ.astro";
import HeroMarquee from "@/components/HeroMarquee.astro";
import SectionVideo from "@/components/SectionVideo.astro";
import { caseStudies, modules } from "@/data/site";

const trustItems = [
  { title: "Not Shared Leads", text: "Capture and convert your own enquiries instead of renting names and numbers from lead sellers." },
  { title: "Not Just Ads", text: "Campaigns can be added later, but the core system fixes what happens after someone contacts you." },
  { title: "Not More Software", text: "We build and manage the system so you are not left learning another platform." },
  { title: "Built For Tradies", text: "Designed around missed calls, quote requests, job details, follow-up, and booking." },
];

const problemItems = [
  { title: "Calls get missed", text: "You are on-site, driving, or quoting when the phone rings." },
  { title: "Enquiries sit waiting", text: "Website forms and messages can sit in an inbox until you have time." },
  { title: "Quotes go cold", text: "Quotes get sent, then follow-up depends on memory." },
  { title: "Opportunities scatter", text: "Phone, email, texts, notes, and old leads never become one clear pipeline." },
];

const heroMarqueeItems = ["Missed Calls", "Instant Replies", "Quote Requests", "Job Details", "Follow-Up", "Pipeline", "Owner Alerts", "Booked Jobs System"];
---

<BaseLayout title="Tradie Front Desk System | More Booked Jobs, Less Chasing" description="A managed front-desk system for tradies that captures enquiries, responds instantly, follows up automatically, and helps turn quote requests into booked jobs.">
  <Hero
    eyebrow="The Tradie Front Desk System by System Pros AI"
    title="More Booked Jobs. Less Chasing. No Tech Headaches."
    text="We install and manage a smart front-desk system for tradies that captures enquiries, responds instantly, follows up automatically, and helps turn quote requests into booked jobs while you stay focused on the work."
    secondary="See How It Works"
    secondaryHref="/how-it-works"
    bullets={["Catch missed calls before they go cold", "Reply to new enquiries instantly", "Follow up without chasing manually", "Organise every opportunity in one simple pipeline", "Add local campaigns only when you are ready"]}
  />

  <HeroMarquee eyebrow="System flow" items={heroMarqueeItems} />

  <FeatureGrid eyebrow="Clear position" title="Not shared leads. Not just ads. Not more software." items={trustItems} columns="four" />

  <section class="section band">
    <div class="container split video-split">
      <div>
        <div class="section-head">
          <p class="eyebrow">The problem</p>
          <h2>Good Jobs Are Slipping Through The Cracks</h2>
          <p class="lead">Most tradies do not lose jobs because they are bad at the work. They lose jobs because the enquiry process breaks down when things get busy.</p>
        </div>
        <div class="grid two">
          {problemItems.map((item) => (
            <div class="card soft">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </div>
          ))}
        </div>
      </div>
      <SectionVideo id="HomeProblemVideo" />
    </div>
  </section>

  <section class="section band">
    <div class="container split video-split">
      <div class="section-head">
        <p class="eyebrow">The reframe</p>
        <h2>Your Trade Business Needs A Front Desk System</h2>
        <p class="lead">You may not have a lead problem first. You may have a missed-call, slow-reply, and follow-up problem.</p>
        <p>Before spending more money getting enquiries, make sure your business can capture, respond to, qualify, book, and follow up with the enquiries it already receives.</p>
        <div class="button-row">
          <a class="btn primary" href="/free-audit">Check Where You're Losing Jobs</a>
          <a class="btn secondary" href="/whats-included">View What's Included</a>
        </div>
      </div>
      <SectionVideo id="HomeReframeVideo" />
    </div>
  </section>

  <ProcessSteps title="How The System Works" />

  <section class="section band">
    <div class="container split video-split">
      <SectionVideo id="HomeFiveStepVideo" />
      <div class="section-head">
        <p class="eyebrow">The mechanism</p>
        <h2>The Five-Step Flow Is The Core</h2>
        <p class="lead">Capture, respond, qualify, book, and follow up gives every enquiry a clearer path from first contact to next action.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split video-split">
      <div>
        <div class="section-head">
          <p class="eyebrow">Modules</p>
          <h2>What Your Front Desk System Can Include</h2>
        </div>
        <div class="grid two">
          {modules.slice(0, 8).map(([title, text]) => (
            <div class="card">
              <h3>{title}</h3>
              <p>{text}</p>
            </div>
          ))}
        </div>
      </div>
      <SectionVideo id="HomeModulesVideo" />
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div class="section-head">
        <p class="eyebrow">Who it is for</p>
        <h2>Built For Busy Trade Businesses</h2>
        <p class="lead">This fits owners who want better enquiry handling before adding more volume.</p>
      </div>
      <div class="grid two">
        <div class="card">
          <h3>Good fit</h3>
          <ul class="list">
            <li>You miss calls while working</li>
            <li>You send quotes but do not always follow up</li>
            <li>You want more booked jobs without chasing manually</li>
            <li>You want to own your customer database</li>
          </ul>
        </div>
        <div class="card">
          <h3>Not a fit</h3>
          <ul class="list">
            <li>You only want cheap shared leads</li>
            <li>You expect guaranteed jobs with no system</li>
            <li>You do not want to improve follow-up</li>
            <li>You have no capacity to take more work</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Proof</p>
        <h2>Systems That Help Support Real Businesses</h2>
        <p class="lead">Case studies are examples only. Results depend on the business, market, offer, implementation, and follow-through.</p>
      </div>
      <div class="split video-split proof-system-feature">
        <div class="card soft">
          <p class="eyebrow">Payment system example</p>
          <h3>From Checkout To Customer Follow-Up</h3>
          <p>A payment page is only one part of the system. The useful layer is what happens around it: customer records, subscriptions, reminders, follow-up, and owner visibility.</p>
          <p class="fineprint">Visual example inspired by a real checkout flow. It does not claim guaranteed revenue, bookings, or customer results.</p>
        </div>
        <SectionVideo id="HomeRealBusinessPaymentVideo" />
      </div>
      <div class="grid three">
        {caseStudies.map((study) => <CaseStudyCard study={study} />)}
      </div>
    </div>
  </section>

  <CTASection title="Find Out Where Your Business Is Losing Jobs" text="Book a Free Tradie Front Desk Audit and we will review how your business handles calls, quote requests, missed calls, follow-up, and customer enquiries." cta="Book My Free Front Desk Audit" />

  <section class="section">
    <div class="container">
      <div class="split video-split package-video-head">
        <div class="section-head">
          <p class="eyebrow">Packages</p>
          <h2>Start With The System That Matches Your Enquiry Process</h2>
          <p class="lead">Pricing depends on scope, services, locations, channels, campaigns, and support needs.</p>
        </div>
        <SectionVideo id="HomeAuditPackagesVideo" />
      </div>
      <PackageCards />
    </div>
  </section>

  <FAQ />
  <CTASection title="Your Trade Business Needs A Front Desk System, Not More Chaos" text="Book a Free Front Desk Audit and get a clear view of what to fix first." />
</BaseLayout>

<style>
  .video-split {
    align-items: center;
  }

  .video-split .grid.two {
    gap: 16px;
  }

  .video-split .card {
    padding: 22px;
  }

  .video-split .card h3 {
    font-size: 22px;
    margin-bottom: 10px;
  }

  .package-video-head {
    margin-bottom: 34px;
  }

  @media (max-width: 920px) {
    .video-split .grid.two {
      grid-template-columns: 1fr;
    }
  }
</style>
