---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import ProcessSteps from "@/components/ProcessSteps.astro";
import CTASection from "@/components/CTASection.astro";
import HeroMarquee from "@/components/HeroMarquee.astro";
import SectionVideo from "@/components/SectionVideo.astro";
import { processSteps } from "@/data/site";

const captureSources = ["Calls", "Missed calls", "Website forms", "Social messages", "Google messages", "Old leads", "Campaign enquiries"];
const scenarioCards = [
  ["Missed call", "The customer gets a fast text-back, shares what they need, and the owner sees the next action."],
  ["Website quote request", "The form gets an instant reply, job details are collected, and follow-up starts if needed."],
  ["After-hours urgent job", "Urgent enquiries can route to the owner or on-call number when that rule is included."],
  ["Quote sent", "The customer is followed up professionally instead of disappearing into memory."],
];
const ownerItems = ["New enquiries", "Missed calls recovered", "Customer replies", "Callback requests", "Quotes needing follow-up", "Won/lost opportunities"];
const customerItems = ["Faster acknowledgement", "Clear next step", "Easy replies", "Helpful reminders", "Professional communication", "Less waiting"];
const heroMarqueeItems = ["Capture", "Respond", "Qualify", "Book", "Follow Up", "Urgent Triage", "Owner Alert", "Customer Experience"];
---

<BaseLayout title="How Tradie Front Desk Works" description="See how Tradie Front Desk captures enquiries, replies fast, qualifies job details, helps book callbacks or site visits, and follows up.">
  <Hero
    eyebrow="How it works"
    title="How Tradie Front Desk Works"
    text="A practical five-step front-desk flow that catches enquiries, replies fast, collects job details, moves customers toward the next step, and follows up when they go quiet."
    primary="Book a Free Front Desk Audit"
    secondary="View Pricing"
    secondaryHref="/pricing"
    videoId="HowItWorksHeroVideo"
  />
  <HeroMarquee eyebrow="Five-step enquiry path" items={heroMarqueeItems} />

  <ProcessSteps title="The System Is Built Around One Simple Flow" text="Every module supports the same goal: make sure every enquiry has a clear next step." />

  <section class="section band">
    <div class="container split video-split">
      <div>
        <div class="section-head">
          <p class="eyebrow">Capture</p>
          <h2>Every Enquiry Needs Somewhere To Go</h2>
          <p class="lead">The first job is to stop enquiries from living across missed calls, inboxes, social messages, old notes, and memory.</p>
        </div>
        <div class="grid two">
          {captureSources.map((item) => <article class="card compact"><h3>{item}</h3></article>)}
        </div>
      </div>
      <SectionVideo id="HowItWorksScenarioVideo" />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid">
        {processSteps.map((step, index) => (
          <article class="card split">
            <div>
              <p class="eyebrow">Step {index + 1}</p>
              <h2>{step.title}</h2>
              <p class="lead">{step.text}</p>
            </div>
            <ul class="list">
              {(index === 0 ? ["Missed calls", "Website quote forms", "Contact forms", "Customer messages", "Old customer lists"] :
                index === 1 ? ["Missed-call text-back", "New enquiry SMS", "Email acknowledgement", "Approved message templates"] :
                index === 2 ? ["Service needed", "Job location", "Urgency", "Photos", "Preferred callback time"] :
                index === 3 ? ["Callback requested", "Quote appointment requested", "Site visit requested", "Owner review required"] :
                ["No-response follow-up", "Quote follow-up", "Old lead reactivation", "Review requests"]).map((item) => <li>{item}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Urgent and after-hours triage</p>
        <h2>Urgent Jobs Do Not Follow The Same Path As Normal Quotes</h2>
        <p class="lead">Plumbing leaks, electrical faults, roof issues, and other urgent requests need clear routing rules. The system can separate urgent handoffs from normal quote follow-up when that scope is included.</p>
      </div>
      <div class="grid three">
        <article class="card"><h3>Urgent path</h3><p>Emergency callouts can route to the owner or on-call number when included.</p></article>
        <article class="card"><h3>Non-urgent path</h3><p>After-hours quote requests can get an instant reply and a callback or site-visit path.</p></article>
        <article class="card"><h3>Safety rule</h3><p>High-risk or pricing-sensitive requests do not get risky promises from automation.</p></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split video-split">
      <div>
        <div class="section-head">
          <p class="eyebrow">Scenarios</p>
          <h2>What This Looks Like In Real Life</h2>
        </div>
        <div class="grid two">
          {scenarioCards.map(([title, text]) => (
            <article class="card">
              <h3>{title}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </div>
      <SectionVideo id="HowItWorksScenarioVideo" />
    </div>
  </section>

  <section class="section band">
    <div class="container grid two">
      <article class="card">
        <h2>What You See As The Owner</h2>
        <ul class="list">{ownerItems.map((item) => <li>{item}</li>)}</ul>
      </article>
      <article class="card">
        <h2>What Your Customer Experiences</h2>
        <ul class="list">{customerItems.map((item) => <li>{item}</li>)}</ul>
      </article>
    </div>
  </section>

  <CTASection title="Want To See Where Your Current Process Is Leaking?" text="Book a Free Front Desk Audit and we will map your enquiry process from first contact to follow-up." cta="Book My Free Audit" />
</BaseLayout>

<style>
  .compact {
    padding: 20px;
  }

  .compact h3 {
    font-size: 22px;
  }
</style>
