---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import CaseStudyCard from "@/components/CaseStudyCard.astro";
import CTASection from "@/components/CTASection.astro";
import HeroMarquee from "@/components/HeroMarquee.astro";
import SectionVideo from "@/components/SectionVideo.astro";
import { caseStudies, proofMetrics } from "@/data/site";

const heroMarqueeItems = ["Calls Caught", "Replies Sent", "Follow-Ups Completed", "Bookings Created", "Reviews Requested", "Scorecard", "Pipeline", "Results Vary"];
const beforeAfterFlows = [
  ["Missed call", "Call is missed and customer moves on.", "Fast text-back, job details, owner handoff."],
  ["Website quote request", "Form sits in email.", "Instant reply, pipeline entry, follow-up task."],
  ["Quote follow-up", "Quote is sent and forgotten.", "Approved follow-up messages and visible outcome."],
  ["Old lead reactivation", "Past enquiries sit untouched.", "Suitable contacts are checked and interested replies are routed."],
];
---

<BaseLayout title="Tradie Front Desk Proof | Real Follow-Up Systems" description="See practical proof examples for Tradie Front Desk, including calls caught, replies sent, follow-ups completed, bookings created, and demo scorecard assets.">
  <Hero
    eyebrow="Proof"
    title="Real Enquiries. Real Follow-Up. Real Systems."
    text="Proof should show the mess before, the system installed, what changed, and which activity was tracked. No hype, no guaranteed results."
    primary="Book a Free Front Desk Audit"
    secondary="View Pricing"
    secondaryHref="/pricing"
    videoId="CaseStudiesHeroVideo"
  />
  <HeroMarquee eyebrow="Proof map" items={heroMarqueeItems} />

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">What we measure</p>
        <h2>Proof Should Be Operational And Visible</h2>
        <p class="lead">The useful evidence is not a vague growth claim. It is what the system caught, sent, followed up, booked, and surfaced for the owner.</p>
      </div>
      <div class="grid five">
        {proofMetrics.map(([title, text]) => (
          <article class="card compact">
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container split video-split">
      <div>
        <div class="section-head">
          <p class="eyebrow">Demo proof stack</p>
          <h2>Proof Assets While The Trade-Specific Library Grows</h2>
          <p class="lead">We can show sample scorecards, missed-call replies, pipeline examples, monthly report structure, and before/after enquiry flows before making any claims about your business.</p>
        </div>
        <p class="fineprint">Case studies and examples are provided for illustration only. Results depend on the business, market, offer, implementation, response speed, and follow-through.</p>
      </div>
      <SectionVideo id="CaseStudyProofVideo" />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Before and after</p>
        <h2>Common Enquiry Leaks The System Makes Visible</h2>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Scenario</th><th>Before</th><th>After</th></tr></thead>
          <tbody>
            {beforeAfterFlows.map((row) => <tr>{row.map((cell) => <td>{cell}</td>)}</tr>)}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Example proof cards</p>
        <h2>System Examples</h2>
      </div>
      <div class="grid three">
        {caseStudies.map((study) => <CaseStudyCard study={study} />)}
      </div>
    </div>
  </section>

  <CTASection title="Want To Find Where Your Business Is Leaking Enquiries?" text="Book a Free Front Desk Audit and we will review your current enquiry process." />
</BaseLayout>

<style>
  .grid.five {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .compact {
    padding: 22px;
  }

  .compact h3 {
    font-size: 22px;
  }

  @media (max-width: 1120px) {
    .grid.five {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .grid.five {
      grid-template-columns: 1fr;
    }
  }
</style>
