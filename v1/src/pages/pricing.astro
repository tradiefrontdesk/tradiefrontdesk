---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import PackageCards from "@/components/PackageCards.astro";
import CTASection from "@/components/CTASection.astro";
import FAQ from "@/components/FAQ.astro";
import HeroMarquee from "@/components/HeroMarquee.astro";
import SectionVideo from "@/components/SectionVideo.astro";

const factors = ["Enquiry channels", "Locations or service areas", "Urgent triage rules", "AI phone usage", "Website work", "Campaigns", "Integrations", "Old lead database size"];
const rows = [
  ["Public starting price", "$1,500 setup + $497/month", "$2,500 setup + $1,200/month", "$4,000 setup + $2,000/month + ad spend"],
  ["Best fit", "Basic leak fixing", "Flagship enquiry handling", "Expansion after core system works"],
  ["Missed-call recovery", "Included", "Included", "Included"],
  ["Instant enquiry reply", "Included", "Included", "Included"],
  ["Quote/site-visit booking", "Basic", "Included", "Included"],
  ["Quote follow-up", "Basic / optional", "Included", "Included"],
  ["Opportunity pipeline", "Basic", "Included", "Included"],
  ["Old lead reactivation", "Add-on", "Add-on", "When listed"],
  ["Review builder", "Add-on", "Add-on", "When listed"],
  ["Local campaigns", "Not included", "Add-on", "When listed"],
  ["AI phone or AI messaging", "Add-on", "Add-on", "If selected"],
];
const paymentOptions = [
  ["Standard setup plus monthly", "Setup covers the build and launch. Monthly covers management, support, monitoring, and optimisation."],
  ["Split setup payment", "Available for good-fit clients where timing is the only blocker."],
  ["Quarterly or annual prepay", "Can include a small value-add bonus instead of deep discounting."],
];
const heroMarqueeItems = ["Starter", "Booked Jobs", "Managed Growth", "Setup Scope", "Monthly Support", "Add-Ons", "Usage Costs", "No Pay-Per-Lead"];
---

<BaseLayout title="Tradie Front Desk Pricing | Packages Built Around Your Enquiry Process" description="View Tradie Front Desk package starting prices, scope, add-ons, payment options, and the Front Desk Launch Guarantee.">
  <Hero
    eyebrow="Packages and pricing"
    title="Packages Built Around Your Enquiry Process"
    text="This is not cheap software or pay-per-lead. It is a managed front-desk system that protects and converts job opportunities."
    primary="Book a Free Audit"
    secondary="See How It Works"
    secondaryHref="/how-it-works"
    videoId="PricingHeroVideo"
  />
  <HeroMarquee eyebrow="Package fit" items={heroMarqueeItems} />

  <section class="section band">
    <div class="container split video-split">
      <div class="section-head">
        <p class="eyebrow">Pricing philosophy</p>
        <h2>Price The Business Function, Not The Tool</h2>
        <p class="lead">The value is fewer missed opportunities, faster replies, better quote follow-up, booked callbacks or site visits, and less owner chasing.</p>
        <p>Final pricing depends on enquiry sources, number of locations, AI phone usage, campaigns, integrations, and the amount of management needed.</p>
      </div>
      <SectionVideo id="PricingPackagesVideo" />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Packages</p>
        <h2>Choose The Right Starting Point</h2>
        <p class="lead">Booked Jobs System is the flagship package for most established tradies with active enquiry handling and quote follow-up needs.</p>
      </div>
      <PackageCards />
      <p class="fineprint" style="margin-top: 18px;">Starting prices are public anchors. Final pricing depends on scope, usage, integrations, campaign needs, and service complexity. Ad spend is separate for campaign packages.</p>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Comparison</p>
        <h2>Package Comparison</h2>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Feature / Service</th><th>Front Desk Starter</th><th>Booked Jobs System</th><th>Managed Growth System</th></tr></thead>
          <tbody>{rows.map((row) => <tr>{row.map((cell) => <td>{cell}</td>)}</tr>)}</tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <article class="card">
        <h2>What Affects Your Setup</h2>
        <ul class="list">{factors.map((factor) => <li>{factor}</li>)}</ul>
      </article>
      <article class="card">
        <p class="eyebrow">Guarantee</p>
        <h2>Front Desk Launch Guarantee</h2>
        <p>Once we have your required business details, access, approvals, and payment, we build, test, and launch the agreed core front-desk system. If something in the agreed core setup is not working as specified, we fix it.</p>
        <p class="fineprint">This does not guarantee exact job numbers, revenue, profit, leads, bookings, ad results, rankings, reviews, or customer behaviour.</p>
      </article>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Payment options</p>
        <h2>Simple Payment Structures</h2>
      </div>
      <div class="grid three">
        {paymentOptions.map(([title, text]) => (
          <article class="card">
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <FAQ />
  <CTASection title="Not Sure Which Package Fits?" text="Book a Free Front Desk Audit and we will recommend the right starting point based on your current enquiry process." cta="Book My Free Audit" />
</BaseLayout>
