---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/home/Hero.astro";
import LeakDiagram from "@/components/home/LeakDiagram.astro";
import Reframe from "@/components/home/Reframe.astro";
import Mechanism from "@/components/home/Mechanism.astro";
import ModuleSchedule from "@/components/home/ModuleSchedule.astro";
import ProofBand from "@/components/home/ProofBand.astro";
import AuditPackages from "@/components/home/AuditPackages.astro";
import FAQ from "@/components/FAQ.astro";
import CTASection from "@/components/CTASection.astro";
import { corePromise, heroPromise } from "@/data/site";
---

<BaseLayout title="Home" description={`${heroPromise} ${corePromise}`}>
  <Hero />
  <LeakDiagram />
  <Reframe />
  <Mechanism />
  <ModuleSchedule />
  <ProofBand />
  <AuditPackages />
  <FAQ />
  <CTASection
    title="See where your front desk is leaking."
    text={`${corePromise} Book a free audit and we'll map where jobs are slipping — no pressure, no lock-in.`}
  />
</BaseLayout>
