---
// privacy-policy.astro — legal document page.
// Design: quiet light-band document page. Compact dark hero strip (see
// LegalHero) then the document body in numbered LegalSection clauses. No
// video (PrivacyPolicyVideo exists on the old site but is skipped here —
// see the wave report), no Reveal on the legal text, no CTASection; the
// final "Privacy Contact" clause is the modest contact pointer the page
// ends on.
//
// Copy: ported verbatim from the old root src/pages/privacy-policy.astro
// per this wave's override — the copy-rewrite rules (banned words, voice)
// do not apply to this body text. Entity names and the effective date are
// pulled from src/data/site.ts `legalDetails` so they stay in sync with
// the rest of the site rather than being retyped.
import BaseLayout from "@/layouts/BaseLayout.astro";
import LegalHero from "@/components/legal/LegalHero.astro";
import LegalSection from "@/components/legal/LegalSection.astro";
import { brand, contactDetails, legalDetails } from "@/data/site";

const collectedInfo = [
  "Name, business name, role, trade or service type, website, service area, phone number, email address, and preferred contact details.",
  "Audit form answers, enquiry problems, service needs, package interest, budget context, message content, preferred call times, and notes from sales or support conversations.",
  "Client onboarding information such as services offered, business hours, urgent job rules, good-fit and bad-fit job criteria, team contacts, notification preferences, and access requirements.",
  "Client customer data where a client provides it or where the system captures it on the client's behalf, including names, phone numbers, emails, job locations, service requests, photos, messages, call notes, quote status, booking status, and follow-up history.",
  "Technical and usage data such as IP address, browser type, device type, pages visited, referral source, form activity, cookie identifiers, analytics events, and basic security logs.",
  "Payment, invoice, subscription, and billing status information where services are purchased. Full payment card details are usually handled by third-party payment providers rather than stored by us.",
];

const useCases = [
  "Respond to enquiries, book audit calls, prepare front-desk reviews, and recommend practical next steps.",
  "Onboard clients, map their enquiry process, build workflows, configure CRM tools, prepare approved messages, and launch the agreed system.",
  "Send customer-facing messages, owner alerts, follow-ups, callback requests, review requests, and campaign communications where authorised.",
  "Provide support, troubleshoot workflows, monitor system activity, improve message quality, manage billing, and keep service records.",
  "Connect forms, calendars, SMS, email, phone, AI, advertising, analytics, hosting, CRM, payment, and notification tools needed to operate the service.",
  "Comply with law, enforce agreements, prevent fraud, protect systems, resolve disputes, and maintain business records.",
];

const sharedWith = [
  "CRM and automation platforms such as GoHighLevel or comparable providers.",
  "Phone, SMS, email, WhatsApp, call recording, and notification providers.",
  "AI providers used for enquiry handling, summaries, classification, message drafting, or phone detail capture.",
  "Calendar, form, website hosting, analytics, security, email, storage, payment, accounting, and document tools.",
  "Advertising and review platforms such as Google, Meta, and review systems where a client has authorised that work.",
  "Professional advisers, support contractors, or service providers who need access to help operate the business or deliver the agreed service.",
  "Authorities, regulators, courts, or other parties where required by law or needed to protect legal rights.",
];

const rights = [
  "Ask what personal information we hold about you.",
  "Ask us to correct inaccurate or outdated information.",
  "Ask us to delete information where deletion is legally and technically appropriate.",
  "Opt out of marketing or non-essential follow-up messages.",
  "Withdraw consent where we rely on consent, subject to legal, contractual, platform, and record-keeping limits.",
  "Raise a privacy concern or complaint using the contact details below.",
];

const securityMeasures = [
  "Limit access to people and tools that need it for delivery, support, billing, or legal reasons.",
  "Use established third-party platforms with their own security and privacy controls.",
  "Review workflows, forms, and message routing before launch where we manage the build.",
  "Encourage clients to keep passwords secure, maintain account access, and remove access that is no longer needed.",
];
---

<BaseLayout
  title="Privacy Policy"
  description="How Tradie Front Desk collects, uses, shares, stores, and protects information through this website and the managed front-desk systems we build for trade businesses."
>
  <LegalHero
    title="Privacy Policy"
    effectiveDate={legalDetails.effectiveDate}
    lead="This policy explains how we collect, use, share, store, and protect information through this website and through the managed front-desk systems we build for trade businesses."
  />

  <section class="section band-light">
    <div class="container legal-doc">
      <LegalSection index={1} heading="1. Who We Are">
        <p>{brand.fullName} is a managed enquiry, follow-up, and booking-support system for trade and service businesses. It is designed by {legalDetails.providerLabel}.</p>
        <p>References to <strong>we</strong>, <strong>us</strong>, and <strong>our</strong> mean the relevant provider entity identified in your proposal, invoice, checkout page, statement of work, or service agreement. If you are a customer of one of our clients, we may handle your information on that client's behalf as part of the front-desk system we manage for them.</p>
      </LegalSection>

      <LegalSection index={2} heading="2. What This Policy Covers">
        <p>This policy covers information collected through this website, audit forms, contact forms, booking requests, emails, calls, SMS messages, CRM tools, automation workflows, AI-assisted tools, and related platforms used to deliver the service.</p>
        <p>Client websites, client businesses, third-party platforms, payment providers, ad platforms, review platforms, and AI providers may also have their own privacy policies and terms.</p>
      </LegalSection>

      <LegalSection index={3} heading="3. Information We May Collect">
        <ul class="legal-list">
          {collectedInfo.map((item) => <li>{item}</li>)}
        </ul>
      </LegalSection>

      <LegalSection index={4} heading="4. How We Collect Information">
        <p>We may collect information when you submit a form, book a call, email us, call us, send a message, buy a service, complete onboarding, give us platform access, provide a customer list, connect a website form, or use a front-desk system we manage.</p>
        <p>We may also receive information from client CRM accounts, connected phone/SMS/email tools, advertising platforms, review platforms, analytics tools, payment tools, and other approved third-party systems.</p>
      </LegalSection>

      <LegalSection index={5} heading="5. How We Use Information">
        <ul class="legal-list">
          {useCases.map((item) => <li>{item}</li>)}
        </ul>
        <p>Where applicable, we may rely on consent, contract performance, legitimate business interests, legal obligations, client instructions, or another lawful basis available in the relevant jurisdiction.</p>
      </LegalSection>

      <LegalSection index={6} heading="6. Client Customer Data">
        <div class="legal-callout">
          <p class="mono-label">Client data</p>
          <p>When a trade business client uses our service, their customer contact data belongs to that client, subject to applicable law, platform terms, payment status, and the written agreement. We use that data to deliver the agreed service, such as enquiry capture, customer replies, quote follow-up, owner alerts, review requests, and pipeline management.</p>
          <p>The client is responsible for confirming that customer lists, old leads, past quotes, and reactivation lists can legally and appropriately be contacted. Contacts who opt out, unsubscribe, or request no further messages must not be contacted through automated campaigns unless legally permitted.</p>
        </div>
      </LegalSection>

      <LegalSection index={7} heading="7. Who We May Share Information With">
        <p>We do not sell personal information as a data broker. We may share information with trusted providers where needed to operate the website, deliver services, manage accounts, or comply with law.</p>
        <ul class="legal-list">
          {sharedWith.map((item) => <li>{item}</li>)}
        </ul>
      </LegalSection>

      <LegalSection index={8} heading="8. International Processing">
        <p>We may work with clients, providers, and tools in New Zealand, Australia, the United States, and other countries. Your information may be processed, stored, or accessed outside your country, depending on the tools and service setup.</p>
        <p>Where required, we will take reasonable steps to use appropriate safeguards for cross-border handling. Some third-party tools may process information under their own privacy terms and security frameworks.</p>
      </LegalSection>

      <LegalSection index={9} heading="9. AI-Assisted Tools">
        <p>AI tools may assist with enquiry handling, summaries, classification, message drafting, website chat, or phone detail capture. AI output can be wrong or incomplete and may require human monitoring and correction.</p>
        <p>AI-assisted workflows should not be used to make risky promises, give exact prices unless approved, confirm complex jobs, handle emergencies without escalation, provide professional technical advice, or replace human judgement.</p>
      </LegalSection>

      <LegalSection index={10} heading="10. Cookies, Analytics, And Tracking">
        <p>This website may use cookies, pixels, analytics, and similar technologies to understand page visits, form activity, referral sources, CTA clicks, website performance, and marketing effectiveness. These tools may collect technical data such as browser type, device information, IP address, pages visited, and event activity.</p>
        <p>You can usually control cookies through your browser settings. Blocking cookies may affect some website functions or measurement accuracy.</p>
      </LegalSection>

      <LegalSection index={11} heading="11. Email, SMS, Calls, And Opt-Outs">
        <p>If you contact us, book an audit, or become a client, we may contact you about your enquiry, audit, proposal, onboarding, service delivery, billing, support, or relevant business updates.</p>
        <p>If you receive marketing or non-essential follow-up, you can ask us to stop. Some transactional, service, billing, security, or legal communications may still be required.</p>
      </LegalSection>

      <LegalSection index={12} heading="12. How Long We Keep Information">
        <p>We keep information only as long as reasonably needed for the purpose collected, service delivery, billing, support, legal compliance, dispute resolution, backups, security, and business records. Retention periods may vary depending on the type of information, the relevant client agreement, the platform used, and legal requirements.</p>
        <p>When information is no longer needed, we may delete, archive, de-identify, or securely retain it where deletion is not technically or legally practical.</p>
      </LegalSection>

      <LegalSection index={13} heading="13. Security">
        <p>We aim to handle information responsibly and use practical safeguards, but no online system can be guaranteed completely secure.</p>
        <ul class="legal-list">
          {securityMeasures.map((item) => <li>{item}</li>)}
        </ul>
        <p>You should not send passwords, payment card numbers, highly sensitive personal information, or emergency details through ordinary website forms unless specifically requested through an appropriate secure process.</p>
      </LegalSection>

      <LegalSection index={14} heading="14. Your Privacy Rights">
        <p>Depending on your location and relationship with us or our client, you may have privacy rights under laws such as New Zealand's Privacy Act 2020, Australia's Privacy Act and Australian Privacy Principles, US privacy and consumer protection rules, UK GDPR, EU GDPR, or other applicable laws.</p>
        <ul class="legal-list">
          {rights.map((item) => <li>{item}</li>)}
        </ul>
        <p>If you are a customer of one of our trade business clients, we may need to refer your request to that client or work with them to respond.</p>
      </LegalSection>

      <LegalSection index={15} heading="15. Children">
        <p>This website and service are intended for trade businesses and business decision-makers. We do not intentionally target children or collect children's information through this website. If you believe a child has provided personal information, contact us so we can review it.</p>
      </LegalSection>

      <LegalSection index={16} heading="16. Policy Updates">
        <p>We may update this Privacy Policy as the website, service, tools, business structure, or legal requirements change. The effective date at the top of this page shows when this version took effect.</p>
      </LegalSection>

      <LegalSection index={17} heading="17. Privacy Contact">
        <p>For privacy requests, corrections, opt-outs, or questions about this policy, contact us at <a href={`mailto:${contactDetails.email}`}>{contactDetails.email}</a>.</p>
        <div class="legal-contact-grid">
          {contactDetails.phones.map((phone) => (
            phone.available ? (
              <a class="legal-contact-grid__item" href={phone.href}>
                <span class="mono-label">{phone.region}</span>
                <strong>{phone.value}</strong>
              </a>
            ) : (
              <div class="legal-contact-grid__item">
                <span class="mono-label">{phone.region}</span>
                <strong>{phone.value}</strong>
              </div>
            )
          ))}
        </div>
      </LegalSection>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-doc {
    max-width: 760px;
  }
</style>
