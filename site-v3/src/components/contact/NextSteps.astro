---
// NextSteps.astro — Section 3 (light)
// A simple 3-beat sequence for what happens after someone reaches out —
// deliberately not a 3-card grid (page-rules bans the "three equal card"
// reflex): a connected blueprint flow instead, mirroring the mechanism
// idiom used elsewhere on the site but scaled down and re-tinted for a
// light band. Orange is used only for the connector line and marker
// borders (shapes), never as step-number text, to keep the light-band
// contrast rule intact. ContactNextStepsVideo closes the section as its
// figure — a precise thematic match for "what happens after you reach out."
import DraftPath from "@/components/motion/DraftPath.astro";
import Reveal from "@/components/motion/Reveal.astro";
import HomeVideo from "@/components/home/HomeVideo.astro";

const steps = [
  {
    title: "We reply",
    text: "You'll hear from us within one business day, usually with a straight answer or a clear next step.",
  },
  {
    title: "A quick call if it helps",
    text: "If it's easier to talk it through, we'll set up a short call at a time that suits you.",
  },
  {
    title: "Audit if it fits",
    text: "If your enquiry process needs a proper look, we'll point you to the free audit as the next step.",
  },
];
---

<section class="ns band-light section">
  <div class="container">
    <header class="ns__head">
      <p class="mono-label ns__cap">What happens next</p>
      <h2 class="ns__title">After you reach out.</h2>
    </header>

    <div class="ns__flow">
      <div class="ns__rail ns__rail--h" aria-hidden="true">
        <DraftPath
          viewBox="0 0 1000 8"
          d="M4 4 L996 4"
          stroke="var(--action)"
          strokeWidth={2}
        />
      </div>
      <div class="ns__rail ns__rail--v" aria-hidden="true">
        <DraftPath
          viewBox="0 0 8 1000"
          d="M4 4 L4 996"
          stroke="var(--action)"
          strokeWidth={2}
        />
      </div>

      <ol class="ns__steps">
        {
          steps.map((step, i) => (
            <Reveal as="li" variant="draft" delay={i * 0.08} class="ns__step">
              <span class="ns__marker mono-label">{String(i + 1).padStart(2, "0")}</span>
              <h3 class="ns__step-title">{step.title}</h3>
              <p class="ns__step-text">{step.text}</p>
            </Reveal>
          ))
        }
      </ol>
    </div>

    <HomeVideo
      id="ContactNextStepsVideo"
      tone="light"
      caption="From your message or audit request to a clear next step."
      class="ns__media"
    />
  </div>
</section>

<style>
  .ns__head {
    max-width: 56ch;
    margin-bottom: clamp(2.25rem, 5vw, 3.5rem);
  }
  .ns__cap {
    color: var(--muted);
    margin-bottom: 0.85rem;
  }
  .ns__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    letter-spacing: -0.02em;
  }

  .ns__flow {
    position: relative;
  }

  .ns__rail--h {
    position: absolute;
    top: 23px;
    left: 14%;
    right: 14%;
    z-index: 0;
  }
  .ns__rail--v {
    display: none;
  }

  .ns__steps {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .ns__step {
    display: grid;
    justify-items: start;
    gap: 0.65rem;
  }

  .ns__marker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1.5px solid var(--action);
    background: var(--canvas-light);
    color: var(--ink);
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .ns__step-title {
    font-size: 1.1875rem;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .ns__step-text {
    color: var(--muted);
    font-size: 0.9375rem;
  }

  .ns__media {
    width: 100%;
    max-width: 420px;
    margin-top: clamp(2.5rem, 5vw, 4rem);
    margin-inline: auto;
  }

  @media (max-width: 900px) {
    .ns__rail--h {
      display: none;
    }
    .ns__rail--v {
      display: block;
      position: absolute;
      top: 8px;
      bottom: 8px;
      left: 22px;
      width: 8px;
      z-index: 0;
    }
    .ns__rail--v :global(.draft-path) {
      height: 100%;
      width: 8px;
    }
    .ns__steps {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
    .ns__step {
      grid-template-columns: 46px minmax(0, 1fr);
      column-gap: 1.25rem;
      align-items: start;
    }
    .ns__marker {
      grid-row: 1 / 3;
    }
    .ns__step-title {
      align-self: center;
    }
  }

  @media (max-width: 400px) {
    .ns__step {
      grid-template-columns: 40px minmax(0, 1fr);
    }
    .ns__marker {
      width: 40px;
      height: 40px;
    }
  }
</style>
