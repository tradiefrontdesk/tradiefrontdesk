---
// ContactSplit.astro — Section 2 (light)
// The page's main event: <ContactForm /> dominant, direct contact details
// (all three regional numbers + email) alongside it as a compact annotated
// list, not a competing card grid. id="contact-form" is the hero's scroll
// anchor.
import Reveal from "@/components/motion/Reveal.astro";
import ContactForm from "@/components/ContactForm.astro";
import { contactDetails } from "@/data/site";
---

<section id="contact-form" class="cs band-light section">
  <div class="container cs__inner">
    <div class="cs__form">
      <ContactForm />
    </div>

    <Reveal as="aside" variant="fade" class="cs__direct">
      <p class="mono-label cs__direct-cap">Direct lines</p>
      <h2 class="cs__direct-title">Rather call or email?</h2>
      <p class="cs__direct-lead">
        Reach us directly in your region, or by email any time.
      </p>

      <ul class="cs__list">
        <li class="cs__item">
          <span class="mono-label cs__item-label">Email</span>
          <a class="cs__item-value" href={`mailto:${contactDetails.email}`}
            >{contactDetails.email}</a
          >
        </li>
        {
          contactDetails.phones.map((phone) => (
            <li class="cs__item">
              <span class="mono-label cs__item-label">{phone.region}</span>
              <a class="cs__item-value" href={phone.href}>{phone.value}</a>
            </li>
          ))
        }
      </ul>
    </Reveal>
  </div>
</section>

<style>
  .cs__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }

  .cs__direct {
    position: sticky;
    top: 1.5rem;
    border: 1px solid var(--line-light);
    border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 3vw, 2rem);
    background: var(--canvas-light);
  }

  .cs__direct-cap {
    color: var(--muted);
    margin-bottom: 0.85rem;
  }

  .cs__direct-title {
    font-size: 1.375rem;
    letter-spacing: -0.02em;
    margin-bottom: 0.65rem;
  }

  .cs__direct-lead {
    color: var(--muted);
    font-size: 0.9375rem;
    line-height: 1.55;
    margin-bottom: 1.5rem;
  }

  .cs__list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1.1rem;
  }

  .cs__item {
    display: grid;
    gap: 0.3rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--line-light);
  }

  .cs__item:first-child {
    padding-top: 0;
    border-top: none;
  }

  .cs__item-label {
    color: var(--muted);
  }

  .cs__item-value {
    color: var(--ink);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    overflow-wrap: anywhere;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .cs__item-value:hover {
    color: var(--action);
  }

  @media (max-width: 900px) {
    .cs__inner {
      grid-template-columns: 1fr;
    }

    .cs__direct {
      position: static;
      order: -1;
    }
  }
</style>
