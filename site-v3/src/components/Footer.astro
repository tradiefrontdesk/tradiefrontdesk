---
// Footer.astro
// Navy band, blueprint-grid backdrop. Sitemap columns, contact details,
// a stamped registration-mark badge (brand device reused from Wordmark),
// and the results disclaimer required on every page.
import Wordmark from "@/components/Wordmark.astro";
import {
  navItems,
  footerLinks,
  brand,
  contactDetails,
  legalDetails,
  disclaimer,
  tradePages,
} from "@/data/site";

const tradeLinks = [
  { href: tradePages.electricians.path, label: "Electricians" },
  { href: tradePages.plumbersDrainage.path, label: "Plumbers / Drainage" },
  { href: tradePages.roofers.path, label: "Roofers" },
];

const companyLinks = footerLinks.filter(
  (link) => !tradeLinks.some((trade) => trade.href === link.href),
);

const legalLinks = [
  { href: "/privacy-policy", label: "Privacy Policy" },
  { href: "/terms", label: "Terms of Service" },
];

const year = new Date().getFullYear();
---

<footer id="site-footer" class="site-footer band-dark blueprint-grid">
  <div class="container site-footer__top">
    <div class="site-footer__brand">
      <a href="/" aria-label="Tradie Front Desk home">
        <Wordmark variant="light" width={188} />
      </a>
      <p class="site-footer__trust">{brand.trustLine}</p>

      <div class="site-footer__badge" aria-hidden="false">
        <svg viewBox="0 0 40 40" class="site-footer__badge-mark" aria-hidden="true">
          <circle cx="20" cy="20" r="17" stroke="#FF5A1F" stroke-width="1.5" fill="none"></circle>
          <line x1="20" y1="4" x2="20" y2="36" stroke="#FF5A1F" stroke-width="1.5"></line>
          <line x1="4" y1="20" x2="36" y2="20" stroke="#FF5A1F" stroke-width="1.5"></line>
          <circle cx="20" cy="20" r="1.6" fill="#FF5A1F"></circle>
        </svg>
        <p class="mono-label site-footer__badge-text">
          Tradie Front Desk · Managed Front Desk Systems · NZ
        </p>
      </div>
    </div>

    <nav class="site-footer__col" aria-label="Sitemap">
      <p class="mono-label site-footer__heading">Navigate</p>
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav class="site-footer__col" aria-label="Trades">
      <p class="mono-label site-footer__heading">For Trades</p>
      <ul>
        {
          tradeLinks.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav class="site-footer__col" aria-label="Company and legal">
      <p class="mono-label site-footer__heading">Company</p>
      <ul>
        {
          companyLinks.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
        {
          legalLinks.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-footer__col site-footer__contact">
      <p class="mono-label site-footer__heading">Contact</p>
      <a class="site-footer__email" href={`mailto:${contactDetails.email}`}>{contactDetails.email}</a>
      <ul class="site-footer__phones">
        {
          contactDetails.phones.map((phone) => (
            <li>
              <span class="mono-label site-footer__region">{phone.region}</span>
              <a href={phone.href}>{phone.value}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="container site-footer__bottom">
    <p class="site-footer__disclaimer">{disclaimer}</p>
    <p class="mono-label site-footer__copyright">
      © {year} {legalDetails.providerLabel}. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    padding-block: clamp(3rem, 6vw, 5rem) 2rem;
  }

  .site-footer__top {
    display: grid;
    grid-template-columns: minmax(220px, 1.3fr) repeat(3, minmax(130px, 1fr)) minmax(190px, 1.15fr);
    gap: 2.5rem;
    padding-bottom: 2.5rem;
  }

  .site-footer__brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .site-footer__trust {
    max-width: 32ch;
    font-size: 0.9375rem;
    color: var(--on-dark-muted);
  }

  .site-footer__badge {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--line-dark);
    border-radius: var(--radius-lg);
    transform: rotate(-1.5deg);
  }

  .site-footer__badge-mark {
    width: 26px;
    height: 26px;
    flex-shrink: 0;
  }

  .site-footer__badge-text {
    color: var(--on-dark-muted);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
  }

  .site-footer__heading {
    color: var(--on-dark-muted);
    margin-bottom: 1rem;
  }

  .site-footer__col ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .site-footer__col a,
  .site-footer__email {
    color: var(--on-dark-body);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .site-footer__col a:hover,
  .site-footer__col a:focus-visible,
  .site-footer__email:hover,
  .site-footer__email:focus-visible {
    color: var(--action);
  }

  .site-footer__contact {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .site-footer__phones {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .site-footer__phones li {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .site-footer__region {
    color: var(--on-dark-muted);
  }

  .site-footer__phones a {
    color: var(--on-dark-body);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .site-footer__phones a:hover,
  .site-footer__phones a:focus-visible {
    color: var(--action);
  }

  .site-footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line-dark);
  }

  .site-footer__disclaimer {
    max-width: 78ch;
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--on-dark-muted);
  }

  .site-footer__copyright {
    color: var(--on-dark-muted);
  }

  @media (max-width: 959px) {
    .site-footer__top {
      grid-template-columns: repeat(2, 1fr);
    }

    .site-footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 599px) {
    .site-footer__top {
      grid-template-columns: 1fr;
    }
  }
</style>
