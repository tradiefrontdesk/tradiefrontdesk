---
// CategoryStatement.astro — why-were-different Section 3 (dark)
// A centred manifesto moment: a stamped category badge ("managed
// front-desk system" — the actual category name, not a decorative
// eyebrow), the three-alternative rejection as the h2, then the plain
// statement of what the system does and the owner-control line. Vertical
// stack, deliberately not a text/media split — breaks the hero's rhythm.
import Reveal from "@/components/motion/Reveal.astro";
---

<section class="cat band-dark blueprint-grid section">
  <div class="container cat__inner">
    <Reveal variant="stamp" class="cat__stamp">
      <svg class="cat__stamp-mark" viewBox="0 0 40 40" aria-hidden="true">
        <circle cx="20" cy="20" r="17"></circle>
        <line x1="20" y1="3" x2="20" y2="37"></line>
        <line x1="3" y1="20" x2="37" y2="20"></line>
        <circle cx="20" cy="20" r="1.6" fill="currentColor" stroke="none"></circle>
      </svg>
      <span class="mono-label">Managed front-desk system</span>
    </Reveal>

    <Reveal as="h2" variant="draft" class="cat__title">
      Not a lead seller. Not an ad agency. Not another app to run.
    </Reveal>

    <p class="cat__lead max-measure">
      Tradie Front Desk installs and manages the front desk your business
      should already have. It captures every enquiry, replies fast while
      you're still on the tools, qualifies the job, books the next step, and
      follows up when customers go quiet.
    </p>

    <p class="cat__control mono-label">You still decide pricing, promises, and which jobs you take on.</p>
  </div>
</section>

<style>
  .cat__inner {
    display: grid;
    justify-items: center;
    text-align: center;
    max-width: 760px;
    margin-inline: auto;
  }

  .cat__stamp {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 0.85rem;
    margin-bottom: 1.75rem;
    border: 1px solid var(--line-dark);
    border-radius: var(--radius-sm);
    color: var(--marker);
    transform: rotate(-1.5deg);
  }
  .cat__stamp .mono-label {
    color: var(--marker);
  }
  .cat__stamp-mark {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 1.5;
    fill: none;
  }

  .cat__title {
    font-size: clamp(1.9rem, 4.6vw, 3.1rem);
    line-height: 1.12;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .cat__lead {
    color: var(--on-dark-body);
    font-size: 1.0625rem;
    margin-bottom: 1.75rem;
  }

  .cat__control {
    color: var(--on-dark-muted);
  }
</style>
