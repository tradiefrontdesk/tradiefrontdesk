---
// Hero.astro — why-were-different Section 1 (dark)
// Compact interior hero (shorter than the homepage hero): blueprint grid,
// an eyebrow that states the three alternatives up front, the h1 landing
// the contrast, one lead paragraph, primary + secondary CTA, the brand
// trust line, and DifferentHeroVideo as a supporting figure.
import Reveal from "@/components/motion/Reveal.astro";
import DraftPath from "@/components/motion/DraftPath.astro";
import HomeVideo from "@/components/home/HomeVideo.astro";
import { brand } from "@/data/site";
---

<section class="wd-hero band-dark blueprint-grid">
  <div class="container wd-hero__inner">
    <div class="wd-hero__copy">
      <div class="wd-hero__eyebrow">
        <span class="mono-label">Not leads. Not ads. Not another app.</span>
        <span class="wd-hero__eyebrow-tick" aria-hidden="true"></span>
        <span class="mono-label wd-hero__eyebrow-alt">A managed front desk instead</span>
      </div>

      <Reveal as="h1" variant="draft" class="wd-hero__title">
        Leads, ads, and apps don't answer your phone. A managed front desk does.
      </Reveal>

      <div class="wd-hero__rule" aria-hidden="true">
        <DraftPath viewBox="0 0 320 8" d="M2 4 L318 4" stroke="var(--action)" strokeWidth={2} />
      </div>

      <p class="wd-hero__sub max-measure">
        Tradie Front Desk isn't a lead seller, an ad agency, or another app to
        babysit. It's a managed front desk, installed and run for your
        business, so calls, quote requests, and follow-ups stop depending on
        anyone's memory.
      </p>

      <div class="wd-hero__cta">
        <a class="btn btn-primary" href="/free-audit" data-hero-cta
          >Book a Free Front Desk Audit</a
        >
        <a class="btn btn-ghost" href="/whats-included">See what's included</a>
      </div>

      <p class="wd-hero__trust">{brand.trustLine}</p>
    </div>

    <div class="wd-hero__media">
      <HomeVideo
        id="DifferentHeroVideo"
        tone="dark"
        caption="Different because the process is the product."
      />
    </div>
  </div>
</section>

<style>
  .wd-hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
  }

  .wd-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: center;
  }

  .wd-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--marker);
    margin-bottom: 1.25rem;
  }
  .wd-hero__eyebrow .mono-label {
    color: var(--marker);
  }
  .wd-hero__eyebrow-alt {
    color: var(--on-dark-muted) !important;
  }
  .wd-hero__eyebrow-tick {
    flex: 1;
    max-width: 56px;
    height: 1px;
    background: repeating-linear-gradient(
      to right,
      var(--line-dark) 0,
      var(--line-dark) 4px,
      transparent 4px,
      transparent 8px
    );
  }

  .wd-hero__title {
    font-size: clamp(2rem, 4.4vw, 3.35rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--on-dark);
    max-width: 19ch;
  }

  .wd-hero__rule {
    width: min(280px, 65%);
    margin-block: 1.25rem;
  }

  .wd-hero__sub {
    color: var(--on-dark-body);
    font-size: 1.0625rem;
  }

  .wd-hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.75rem;
  }

  .wd-hero__trust {
    margin-top: 1.25rem;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--on-dark-muted);
    max-width: 46ch;
  }

  .wd-hero__media {
    width: 100%;
  }

  @media (max-width: 900px) {
    .wd-hero__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .wd-hero__title {
      max-width: 100%;
    }
    .wd-hero__media {
      max-width: 420px;
      margin-inline: auto;
    }
  }
</style>
