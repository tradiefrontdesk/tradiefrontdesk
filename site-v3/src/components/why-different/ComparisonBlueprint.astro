---
// ComparisonBlueprint.astro — why-were-different Section 2 (light)
// The centrepiece: ONE annotated blueprint artifact, not three equal cards.
// A bordered "spec sheet" table — dark title-block header row, mono column
// labels, a decorative measurement-tick ruler, and the "Tradie Front Desk"
// column called out with a background tint (never a colour accent border).
// Reflows to stacked label:value blocks per row under 760px so nothing
// scrolls horizontally on mobile. DifferentComparisonVideo closes the
// section as its figure.
import HomeVideo from "@/components/home/HomeVideo.astro";

const columns = ["Lead sellers", "Ad agencies", "DIY apps", "Tradie Front Desk"];

const rows: Array<{ spec: string; values: [string, string, string, string] }> = [
  {
    spec: "What you actually get",
    values: [
      "Shared names and numbers, sold to other tradies too.",
      "More clicks and traffic to your number or form.",
      "Another login, with the setup work still on you.",
      "Your own enquiries, captured and worked from first contact.",
    ],
  },
  {
    spec: "Who answers when you can't",
    values: [
      "No one. The lead is yours to chase.",
      "No one. Their job stops at the click.",
      "Only what you've configured yourself, if you've had time.",
      "The system does, on rules you approve.",
    ],
  },
  {
    spec: "Who chases the quote",
    values: [
      "Nobody. It was never theirs to chase.",
      "Not their job.",
      "You, whenever the app reminds you.",
      "Built in, so Friday's quote gets chased Monday.",
    ],
  },
  {
    spec: "Who runs it day to day",
    values: [
      "Their sales team, on their terms.",
      "Their media buyers, reporting on spend.",
      "You, learning and maintaining the software.",
      "We install it, test it, and manage it for you.",
    ],
  },
  {
    spec: "Who owns the customer",
    values: [
      "Shared with whoever else bought the lead.",
      "You own the click, not the process after it.",
      "You, in full, if you keep the system running.",
      "You, always. Pricing, promises, and job selection stay yours.",
    ],
  },
];
---

<section class="cmp band-light section">
  <div class="container">
    <header class="cmp__head">
      <p class="mono-label cmp__cap">Fig. — spec sheet: three ways vs. the front desk</p>
      <h2 class="cmp__title">The same five questions, four different answers.</h2>
      <p class="cmp__lead max-measure">
        Every trade business has tried some mix of these. Laid out side by
        side, the gap is not marketing, it's what happens after someone
        contacts you.
      </p>
    </header>

    <div class="cmp__artifact surface-light">
      <div class="cmp__ruler" aria-hidden="true">
        <svg viewBox="0 0 640 16" preserveAspectRatio="none">
          {
            Array.from({ length: 33 }).map((_, i) => (
              <line
                x1={i * 20}
                x2={i * 20}
                y1={0}
                y2={i % 4 === 0 ? 16 : 9}
                stroke="var(--line-light)"
                stroke-width="1"
              />
            ))
          }
        </svg>
      </div>

      <table class="cmp__table">
        <caption class="sr-only">
          Comparison of lead sellers, ad agencies, DIY apps, and Tradie Front Desk
          across five criteria
        </caption>
        <thead>
          <tr>
            <th scope="col" class="mono-label cmp__spec-head">Spec</th>
            {
              columns.map((col) => (
                <th
                  scope="col"
                  class:list={["mono-label", col === "Tradie Front Desk" && "cmp__col--us"]}
                >
                  {col}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            rows.map((row) => (
              <tr>
                <th scope="row" class="cmp__row-head">
                  {row.spec}
                </th>
                {row.values.map((value, i) => (
                  <td
                    data-label={columns[i]}
                    class:list={[columns[i] === "Tradie Front Desk" && "cmp__col--us"]}
                  >
                    {value}
                  </td>
                ))}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <HomeVideo
      id="DifferentComparisonVideo"
      tone="light"
      caption="From loose leads and quiet quotes to one managed process."
      class="cmp__media"
    />
  </div>
</section>

<style>
  .cmp__head {
    max-width: 62ch;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .cmp__cap {
    color: var(--muted);
    margin-bottom: 0.85rem;
  }
  .cmp__title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .cmp__lead {
    color: var(--body);
    font-size: 1.0625rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .cmp__artifact {
    overflow: hidden;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }

  .cmp__ruler {
    padding: 0.6rem 1.25rem 0;
    background: var(--surface-light);
  }
  .cmp__ruler svg {
    width: 100%;
    height: 12px;
    display: block;
  }

  .cmp__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }

  .cmp__table thead th {
    background: var(--canvas-dark);
    color: var(--on-dark);
    text-align: left;
    padding: 0.9rem 1.1rem;
  }
  .cmp__table thead th.cmp__col--us {
    color: var(--action);
  }
  .cmp__spec-head {
    color: var(--on-dark-muted) !important;
  }

  .cmp__table tbody th,
  .cmp__table tbody td {
    padding: 1rem 1.1rem;
    border-bottom: 1px solid var(--line-light);
    vertical-align: top;
    text-align: left;
  }

  .cmp__table tbody tr:last-child th,
  .cmp__table tbody tr:last-child td {
    border-bottom: none;
  }

  .cmp__row-head {
    font-family: var(--font-display);
    font-weight: 700;
    font-variation-settings: "wdth" 125;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
    color: var(--ink);
    background: var(--canvas-light);
  }

  .cmp__table tbody td {
    color: var(--body);
    background: var(--surface-light);
  }

  .cmp__table td.cmp__col--us {
    background: color-mix(in oklch, var(--action) 8%, var(--surface-light));
    color: var(--ink);
    font-weight: 500;
  }

  /* Mobile: reflow the table into stacked label:value blocks per criterion —
     one artifact, five blocks, no horizontal scroll and no card-grid. */
  @media (max-width: 760px) {
    .cmp__ruler {
      display: none;
    }

    .cmp__table thead {
      display: none;
    }

    .cmp__table,
    .cmp__table tbody,
    .cmp__table tr {
      display: block;
      width: 100%;
    }

    .cmp__table tbody tr {
      border-bottom: 1px solid var(--line-light);
      padding-block: 0.25rem 0.75rem;
    }
    .cmp__table tbody tr:last-child {
      border-bottom: none;
    }

    .cmp__row-head {
      display: block;
      background: var(--canvas-light);
      padding: 0.85rem 1.1rem 0.6rem;
      border-bottom: none;
      white-space: normal;
    }

    .cmp__table tbody td {
      display: block;
      padding: 0.55rem 1.1rem;
      border-bottom: none;
    }

    .cmp__table tbody td::before {
      content: attr(data-label);
      display: block;
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 500;
      color: var(--muted);
      margin-bottom: 0.2rem;
    }

    .cmp__table td.cmp__col--us::before {
      color: var(--ink);
      font-weight: 700;
    }
  }

  .cmp__media {
    max-width: 460px;
    margin-inline: auto;
  }
</style>
