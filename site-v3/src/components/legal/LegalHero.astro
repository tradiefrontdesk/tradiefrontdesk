---
// LegalHero.astro — compact dark hero strip for legal/document pages
// (privacy-policy, terms). Shorter than a normal interior hero: eyebrow,
// h1, the effective date as a mono-label (not prose), one lead line. No
// CTA button, no video, no Reveal — this is a quiet document cover sheet,
// not a persuasion moment.
interface Props {
  title: string;
  effectiveDate: string;
  lead: string;
}

const { title, effectiveDate, lead } = Astro.props;
---

<section class="lh band-dark blueprint-grid">
  <div class="container lh__inner">
    <p class="mono-label lh__eyebrow">Legal</p>
    <h1 class="lh__title">{title}</h1>
    <p class="mono-label lh__date">Effective {effectiveDate}</p>
    <p class="lh__lead max-measure">{lead}</p>
  </div>
</section>

<style>
  .lh {
    padding-block: clamp(2.25rem, 5.5vw, 3.75rem);
  }

  .lh__inner {
    max-width: 60ch;
  }

  .lh__eyebrow {
    color: var(--marker);
    margin-bottom: 1rem;
  }

  .lh__title {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--on-dark);
  }

  .lh__date {
    color: var(--on-dark-muted);
    margin-top: 0.9rem;
  }

  .lh__lead {
    color: var(--on-dark-body);
    font-size: 1.0625rem;
    margin-top: 1.1rem;
  }
</style>
