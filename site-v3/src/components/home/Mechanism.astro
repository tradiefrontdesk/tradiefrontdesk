---
// Mechanism.astro — Section 4 (dark) — the centerpiece
// Capture -> Respond -> Qualify -> Book -> Follow Up as a blueprint flow: five
// numbered nodes connected by a DraftPath rail that draws itself in on scroll
// (horizontal on desktop, vertical on mobile). Motion is motivated: the line
// drawing across is the sequence revealing itself. HomeFiveStepVideo closes
// the section as its figure.
import DraftPath from "@/components/motion/DraftPath.astro";
import Reveal from "@/components/motion/Reveal.astro";
import HomeVideo from "@/components/home/HomeVideo.astro";
import { processSteps } from "@/data/site";
---

<section class="mech band-dark blueprint-grid section">
  <div class="container">
    <header class="mech__head">
      <p class="mono-label mech__cap">Fig. 03 — the front desk flow</p>
      <h2 class="mech__title">One clear path for every enquiry.</h2>
      <p class="mech__lead max-measure">
        Five steps run behind the scenes on every call, form, and message — so
        nothing rides on memory, and you stay in control of the decisions that
        matter.
      </p>
    </header>

    <div class="mech__flow">
      <div class="mech__rail mech__rail--h" aria-hidden="true">
        <DraftPath
          viewBox="0 0 1000 8"
          d="M4 4 L996 4"
          stroke="var(--action)"
          strokeWidth={2}
        />
      </div>
      <div class="mech__rail mech__rail--v" aria-hidden="true">
        <DraftPath
          viewBox="0 0 8 1000"
          d="M4 4 L4 996"
          stroke="var(--action)"
          strokeWidth={2}
        />
      </div>

      <ol class="mech__steps">
        {
          processSteps.map((step, i) => (
            <Reveal as="li" variant="draft" delay={i * 0.08} class="mech__step">
              <span class="mech__marker mono-label">{String(i + 1).padStart(2, "0")}</span>
              <h3 class="mech__step-title">{step.title}</h3>
              <p class="mech__step-text">{step.text}</p>
            </Reveal>
          ))
        }
      </ol>
    </div>

    <HomeVideo
      id="HomeFiveStepVideo"
      tone="dark"
      caption="Capture, respond, qualify, book, follow up — one managed process."
      class="mech__media"
    />
  </div>
</section>

<style>
  .mech__head {
    max-width: 56ch;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .mech__cap {
    color: var(--marker);
    margin-bottom: 0.85rem;
  }
  .mech__title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .mech__lead {
    color: var(--on-dark-body);
    font-size: 1.0625rem;
  }

  .mech__flow {
    position: relative;
  }

  /* Horizontal rail passes through the marker centres (markers are opaque and
     mask its ends, so a full-width line reads as a connector between them). */
  .mech__rail--h {
    position: absolute;
    top: 23px;
    left: 9%;
    right: 9%;
    z-index: 0;
  }
  .mech__rail--v {
    display: none;
  }

  .mech__steps {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .mech__step {
    display: grid;
    justify-items: start;
    gap: 0.65rem;
  }

  .mech__marker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1.5px solid var(--action);
    background: var(--canvas-dark);
    color: var(--action);
    font-size: 0.8125rem;
    font-weight: 600;
  }

  .mech__step-title {
    font-size: 1.1875rem;
    letter-spacing: -0.01em;
    color: var(--on-dark);
  }
  .mech__step-text {
    color: var(--on-dark-muted);
    font-size: 0.9375rem;
  }

  .mech__media {
    width: 100%;
    max-width: 460px;
    margin-top: clamp(2.5rem, 5vw, 4rem);
    margin-inline: auto;
  }

  @media (max-width: 980px) {
    .mech__rail--h {
      display: none;
    }
    .mech__rail--v {
      display: block;
      position: absolute;
      top: 8px;
      bottom: 8px;
      left: 22px;
      width: 8px;
      z-index: 0;
    }
    .mech__rail--v :global(.draft-path) {
      height: 100%;
      width: 8px;
    }
    .mech__steps {
      grid-template-columns: 1fr;
      gap: 1.75rem;
      padding-left: 0;
    }
    .mech__step {
      grid-template-columns: 46px minmax(0, 1fr);
      column-gap: 1.25rem;
      align-items: start;
    }
    .mech__marker {
      grid-row: 1 / 3;
    }
    .mech__step-title {
      align-self: center;
    }
  }

  @media (max-width: 400px) {
    .mech__step {
      grid-template-columns: 40px minmax(0, 1fr);
    }
    .mech__marker {
      width: 40px;
      height: 40px;
    }
  }
</style>
