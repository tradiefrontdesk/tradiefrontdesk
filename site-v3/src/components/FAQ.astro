---
// FAQ.astro
// Clean disclosure list (no card grid). Note: the v1 source also rendered
// <TradieTestimonials client:visible /> inline above the FAQ list, but that
// component is out of this task's scope (not in the Task 8 file list, and
// not yet ported to site-v3) so it is intentionally omitted here.
import { faqs } from "@/data/site";

interface Props {
  items?: [string, string][];
  title?: string;
}

const { items = faqs, title = "Common Questions" } = Astro.props;
---

<section class="section faq band-light">
  <div class="container faq__wrap">
    <div class="faq__head">
      <p class="mono-label faq__eyebrow">FAQ</p>
      <h2>{title}</h2>
    </div>
    <div class="faq__list">
      {
        items.map(([question, answer], i) => (
          <details class="faq__item">
            <summary class="faq__summary">
              <span class="mono-label faq__index">FAQ. {String(i + 1).padStart(2, "0")}</span>
              <span class="faq__question">{question}</span>
              <span class="faq__icon" aria-hidden="true" />
            </summary>
            <p class="faq__answer">{answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq__wrap {
    max-width: 860px;
  }

  .faq__head {
    margin-bottom: 2.5rem;
  }

  .faq__eyebrow {
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .faq__list {
    border-top: 1px solid var(--line-light);
  }

  .faq__item {
    border-bottom: 1px solid var(--line-light);
  }

  .faq__summary {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.25rem;
    padding-block: 1.5rem;
    cursor: pointer;
    list-style: none;
  }

  .faq__summary::-webkit-details-marker {
    display: none;
  }

  .faq__index {
    color: var(--ink);
    white-space: nowrap;
  }

  .faq__question {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.0625rem;
    line-height: 1.3;
    color: var(--ink);
    font-variation-settings: "wdth" 125;
  }

  .faq__icon {
    position: relative;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .faq__icon::before,
  .faq__icon::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    background: var(--ink);
    transition: transform var(--dur-base) var(--ease-out);
  }

  .faq__icon::before {
    width: 14px;
    height: 2px;
    transform: translate(-50%, -50%);
  }

  .faq__icon::after {
    width: 2px;
    height: 14px;
    transform: translate(-50%, -50%);
  }

  .faq__item[open] .faq__icon::after {
    transform: translate(-50%, -50%) rotate(90deg) scale(0);
  }

  .faq__answer {
    padding-bottom: 1.5rem;
    padding-right: 2.5rem;
    max-width: 68ch;
    color: var(--body);
  }

  @media (max-width: 640px) {
    .faq__summary {
      gap: 0.85rem;
    }

    .faq__answer {
      padding-right: 0;
    }
  }
</style>
