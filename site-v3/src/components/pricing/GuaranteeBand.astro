---
// GuaranteeBand.astro — Section 6 (light)
// The Front Desk Launch Guarantee, presented as a stamped certificate panel.
// The Q/A text is the site.ts faqs guarantee entry verbatim, unedited — this
// is the highest-stakes copy on the page, so it is reproduced exactly rather
// than paraphrased. The stamp uses orange as a fill/shape only (never text),
// which keeps it compliant with the light-band orange rule.
import Reveal from "@/components/motion/Reveal.astro";
import { faqs } from "@/data/site";

const guaranteeEntry = faqs.find(([q]) => q === "Can you guarantee more jobs?");
const [question, answer] = guaranteeEntry ?? ["Can you guarantee more jobs?", ""];
---

<section class="gb band-light section">
  <div class="container gb__inner">
    <Reveal variant="stamp" class="gb__badge">
      <svg class="gb__badge-mark" viewBox="0 0 40 40" aria-hidden="true">
        <circle cx="20" cy="20" r="18" fill="var(--action)"></circle>
        <path
          d="M12 20.5 L17.5 26 L28.5 14"
          fill="none"
          stroke="var(--on-action)"
          stroke-width="2.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        ></path>
      </svg>
    </Reveal>

    <div class="gb__copy">
      <p class="mono-label gb__cap">Guarantee</p>
      <h2 class="gb__title">Front Desk Launch Guarantee</h2>
      <div class="gb__qa">
        <p class="mono-label gb__q">{question}</p>
        <p class="gb__a max-measure">{answer}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .gb__inner {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(1.75rem, 4vw, 2.75rem);
    align-items: start;
  }

  .gb__badge {
    display: inline-flex;
  }
  .gb__badge-mark {
    width: 64px;
    height: 64px;
  }

  .gb__cap {
    color: var(--muted);
    margin-bottom: 0.75rem;
  }
  .gb__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .gb__qa {
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
    border: 1px solid var(--line-light);
    border-radius: var(--radius-md);
    background: var(--surface-light);
  }
  .gb__q {
    color: var(--ink);
    margin-bottom: 0.6rem;
  }
  .gb__a {
    color: var(--body);
    font-size: 1rem;
  }

  @media (max-width: 640px) {
    .gb__inner {
      grid-template-columns: 1fr;
    }
    .gb__badge-mark {
      width: 48px;
      height: 48px;
    }
  }
</style>
