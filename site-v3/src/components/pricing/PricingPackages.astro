---
// PricingPackages.astro — Section 3 (dark)
// The full package spec sheet — unlike the homepage's AuditPackages (which
// truncates to a 7-item teaser), this is the definitive listing: every
// include AND every exclude, per site.ts, with the flagship (Booked Jobs
// System) carrying the orange border + primary button. Depth on this dark
// band comes from tonal stepping (surface-dark -> surface-dark-2 for the
// featured card), never a box-shadow (see DESIGN.md's Tonal-Not-Shadow
// rule). The disclaimer sits directly under the grid, per the page brief.
import Reveal from "@/components/motion/Reveal.astro";
import HomeVideo from "@/components/home/HomeVideo.astro";
import { packages, disclaimer } from "@/data/site";
---

<section id="packages" class="pp band-dark blueprint-grid section">
  <div class="container">
    <header class="pp__head">
      <div class="pp__intro">
        <p class="mono-label pp__cap">Package spec sheet</p>
        <h2 class="pp__title">Three starting points. One free audit to confirm the fit.</h2>
        <p class="pp__lead max-measure">
          Pricing starts with your enquiry process, not a fixed plan. These
          are the public starting points — your final scope and price get
          confirmed in a free audit.
        </p>
      </div>
      <HomeVideo
        id="PricingPackagesVideo"
        tone="dark"
        caption="Package tiers move from Starter to Booked Jobs to Managed Growth."
        class="pp__media"
      />
    </header>

    <ul class="pp__grid" aria-label="Packages">
      {
        packages.map((pkg) => {
          const featured = Boolean(pkg.featured);
          return (
            <Reveal
              as="li"
              variant={featured ? "stamp" : "draft"}
              class:list={["pkg", { "pkg--featured": featured }]}
            >
              <div class="pkg__top">
                <span class:list={["mono-label", "pkg__badge", { "pkg__badge--featured": featured }]}>
                  {pkg.badge}
                </span>
              </div>
              <h3 class="pkg__name">{pkg.name}</h3>
              <p class="pkg__price mono-label">{pkg.price}</p>
              <p class="pkg__bestfor">{pkg.bestFor}</p>

              <div class="pkg__section">
                <p class="mono-label pkg__section-label">Included</p>
                <ul class="pkg__list pkg__list--include">
                  {pkg.includes.map((item) => (
                    <li>
                      <span class="pkg__tick" aria-hidden="true" />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>

              <div class="pkg__section">
                <p class="mono-label pkg__section-label">Not included</p>
                <ul class="pkg__list pkg__list--exclude">
                  {pkg.excludes.map((item) => (
                    <li>
                      <span class="pkg__dash" aria-hidden="true" />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>

              <a
                class:list={["btn", featured ? "btn-primary" : "btn-ghost", "pkg__cta"]}
                href="/free-audit"
              >
                {pkg.cta}
              </a>
            </Reveal>
          );
        })
      }
    </ul>

    <p class="pp__disclaimer max-measure">{disclaimer}</p>
  </div>
</section>

<style>
  .pp__head {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    gap: clamp(1.75rem, 4vw, 3.25rem);
    align-items: center;
    margin-bottom: clamp(2.25rem, 4vw, 3.25rem);
  }
  .pp__cap {
    color: var(--marker);
    margin-bottom: 0.85rem;
  }
  .pp__title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .pp__lead {
    color: var(--on-dark-body);
    font-size: 1.0625rem;
  }
  .pp__media {
    max-width: 320px;
    justify-self: end;
    width: 100%;
  }

  .pp__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    align-items: start;
  }

  .pkg {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    padding: clamp(1.5rem, 2.5vw, 2rem);
    background: var(--surface-dark);
    border: 1px solid var(--line-dark);
    border-radius: var(--radius-lg);
  }
  .pkg--featured {
    background: var(--surface-dark-2);
    border: 1.5px solid var(--action);
  }

  .pkg__badge {
    display: inline-block;
    color: var(--on-dark-muted);
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--line-dark);
    border-radius: var(--radius-sm);
  }
  .pkg__badge--featured {
    color: var(--on-action);
    background: var(--action);
    border-color: var(--action);
  }

  .pkg__name {
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    color: var(--on-dark);
  }
  .pkg__price {
    color: var(--on-dark);
    font-size: 1.0625rem;
    letter-spacing: 0.01em;
    text-transform: none;
  }
  .pkg__bestfor {
    color: var(--on-dark-body);
    font-size: 0.9375rem;
    padding-bottom: 0.25rem;
  }

  .pkg__section {
    padding-top: 0.6rem;
    border-top: 1px solid var(--line-dark);
    display: grid;
    gap: 0.6rem;
  }
  .pkg__section-label {
    color: var(--on-dark-muted);
  }

  .pkg__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }
  .pkg__list li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.6rem;
    align-items: start;
    font-size: 0.9063rem;
  }
  .pkg__list--include li {
    color: var(--on-dark-body);
  }
  .pkg__list--exclude li {
    color: var(--on-dark-muted);
  }

  .pkg__tick {
    margin-top: 0.45rem;
    width: 8px;
    height: 8px;
    border-radius: 1px;
    background: var(--action);
    transform: rotate(45deg);
    flex-shrink: 0;
  }
  .pkg__dash {
    margin-top: 0.55rem;
    width: 8px;
    height: 1.5px;
    background: var(--on-dark-muted);
    flex-shrink: 0;
  }

  .pkg__cta {
    margin-top: 0.5rem;
    width: 100%;
  }

  .pp__disclaimer {
    margin-top: clamp(2rem, 4vw, 2.75rem);
    padding-top: clamp(1.25rem, 2.5vw, 1.75rem);
    border-top: 1px solid var(--line-dark);
    color: var(--on-dark-muted);
    font-size: 0.8125rem;
    line-height: 1.6;
  }

  @media (max-width: 960px) {
    .pp__head {
      grid-template-columns: 1fr;
    }
    .pp__media {
      justify-self: start;
      max-width: 400px;
    }
    .pp__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
    }
  }
</style>
