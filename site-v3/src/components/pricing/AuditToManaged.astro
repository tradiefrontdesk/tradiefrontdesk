---
// AuditToManaged.astro — Section 5 (dark)
// What happens after you book: audit -> recommendation -> setup -> managed.
// A four-step "job sheet" strip, dash-connected like a schedule, distinct
// from the mechanism's big-node flow and the audit-path strip on the
// homepage's AuditPackages.
import Reveal from "@/components/motion/Reveal.astro";

const steps: [string, string][] = [
  ["Audit", "We map your current enquiry process end to end and show you exactly where jobs are leaking."],
  ["Recommendation", "You get a clear package recommendation based on what the audit finds — no pressure, no lock-in."],
  ["Setup", "If you go ahead, we build, test, and launch the agreed system around your business."],
  ["Managed", "Once live, we monitor, support, and report on the system every month."],
];
---

<section class="atm band-dark blueprint-grid section">
  <div class="container">
    <header class="atm__head">
      <p class="mono-label atm__cap">After you book</p>
      <h2 class="atm__title">From audit to a managed front desk.</h2>
      <p class="atm__lead max-measure">
        Booking the audit does not commit you to anything. Here is what
        happens if you go ahead.
      </p>
    </header>

    <ol class="atm__steps" aria-label="What happens after you book the audit">
      {
        steps.map(([title, text], i) => (
          <Reveal as="li" variant="draft" delay={i * 0.07} class="atm__step">
            <span class="mono-label atm__num">{String(i + 1).padStart(2, "0")}</span>
            <h3 class="atm__step-title">{title}</h3>
            <p class="atm__step-text">{text}</p>
          </Reveal>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .atm__head {
    max-width: 56ch;
    margin-bottom: clamp(2.25rem, 4vw, 3.25rem);
  }
  .atm__cap {
    color: var(--marker);
    margin-bottom: 0.85rem;
  }
  .atm__title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .atm__lead {
    color: var(--on-dark-body);
    font-size: 1.0625rem;
  }

  .atm__steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .atm__step {
    position: relative;
    display: grid;
    align-content: start;
    gap: 0.5rem;
    padding-top: 1.1rem;
  }
  .atm__step::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--action);
  }

  .atm__num {
    color: var(--on-dark-muted);
  }
  .atm__step-title {
    font-size: 1.1875rem;
    letter-spacing: -0.01em;
    color: var(--on-dark);
  }
  .atm__step-text {
    color: var(--on-dark-body);
    font-size: 0.9375rem;
  }

  @media (max-width: 780px) {
    .atm__steps {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      row-gap: 1.75rem;
    }
  }

  @media (max-width: 480px) {
    .atm__steps {
      grid-template-columns: 1fr;
    }
  }
</style>
