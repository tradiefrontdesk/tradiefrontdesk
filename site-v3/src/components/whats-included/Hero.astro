---
// Hero.astro — What's Included, Section 1 (dark)
// Compact interior hero (shorter than the homepage hero, no video required
// per page-rules.md): blueprint grid, a single mono eyebrow, the h1 rising
// in with Reveal(draft), a short DraftPath rule, one lead paragraph, and the
// primary CTA carrying [data-hero-cta]. No fig caption here — there is
// nothing on this band to genuinely annotate.
import Reveal from "@/components/motion/Reveal.astro";
import DraftPath from "@/components/motion/DraftPath.astro";
---

<section class="wi-hero band-dark blueprint-grid">
  <div class="container wi-hero__inner">
    <p class="mono-label wi-hero__eyebrow">The front desk system, module by module</p>

    <Reveal as="h1" variant="draft" class="wi-hero__title">
      What's included in your front desk system.
    </Reveal>

    <div class="wi-hero__rule" aria-hidden="true">
      <DraftPath viewBox="0 0 280 8" d="M2 4 L278 4" stroke="var(--action)" strokeWidth={2} />
    </div>

    <p class="wi-hero__lead max-measure">
      The system is built from modules, not a fixed bundle. Below is what
      each one does, why it matters on a real job, and which ones stay
      optional until you are ready for them.
    </p>

    <div class="wi-hero__cta">
      <a class="btn btn-primary" href="/free-audit" data-hero-cta
        >Book a Free Front Desk Audit</a
      >
      <a class="btn btn-ghost" href="/pricing">See package pricing</a>
    </div>
  </div>
</section>

<style>
  .wi-hero {
    padding-block: clamp(2.75rem, 7vw, 5rem);
  }

  .wi-hero__inner {
    max-width: 62ch;
  }

  .wi-hero__eyebrow {
    color: var(--marker);
    margin-bottom: 1.25rem;
  }

  .wi-hero__title {
    font-size: clamp(2rem, 4.5vw, 3.4rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--on-dark);
    max-width: 18ch;
  }

  .wi-hero__rule {
    width: min(280px, 60%);
    margin-block: 1.35rem;
  }

  .wi-hero__lead {
    color: var(--on-dark-body);
    font-size: 1.0625rem;
  }

  .wi-hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.75rem;
  }
</style>
